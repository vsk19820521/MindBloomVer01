{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/register",        "destination": "/api/user.js" },
    { "source": "/api/login",           "destination": "/api/user.js" },
    { "source": "/api/save-user",       "destination": "/api/user.js" },
    { "source": "/api/get-user",        "destination": "/api/user.js" },
    { "source": "/api/list-users",      "destination": "/api/user.js" },
    { "source": "/api/delete-user",     "destination": "/api/user.js" },
    { "source": "/api/puzzle-averages", "destination": "/api/telemetry.js" },
    { "source": "/api/log-event",       "destination": "/api/telemetry.js" },
    { "source": "/api/upload-drawing",  "destination": "/api/drawings.js" },
    { "source": "/api/get-drawing-url", "destination": "/api/drawings.js" },
    { "source": "/api/cron-delete-drawings", "destination": "/api/cron-delete-drawings.js" },
    { "source": "/api/admin-users",     "destination": "/api/admin.js" },
    { "source": "/api/admin-puzzles",   "destination": "/api/admin.js" },
    { "source": "/api/admin-failures",  "destination": "/api/admin.js" },
    { "source": "/api/admin-reports",   "destination": "/api/admin.js" },
    { "source": "/api/admin-resolve-reports", "destination": "/api/admin.js" },
    { "source": "/api/log-failure",     "destination": "/api/telemetry.js" },
    { "source": "/api/report-puzzle",   "destination": "/api/telemetry.js" }
  ],
  "crons": [
    {
      "path": "/api/cron-delete-drawings",
      "schedule": "0 2 * * *"
    }
  ]
}
