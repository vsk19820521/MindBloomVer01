# MindBloom — Environment Variables
# Copy this file to .env.local for local Vercel CLI development.
# In production, set these in your Vercel dashboard → Project Settings → Environment Variables.

# ──────────────────────────────────────────────────────────────────────
# Supabase
# Found at: https://supabase.com → Your Project → Settings → API
# ──────────────────────────────────────────────────────────────────────

# Your Supabase project URL (safe to be public)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Service Role Key — ⚠️ KEEP SECRET — never expose in frontend code
# This key bypasses Row Level Security and is used server-side only.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_SERVICE_KEY
